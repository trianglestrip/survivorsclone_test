# Ensure text files are normalized and saved as UTF-8
*.gd text eol=lf
*.tscn text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf
*.sh text eol=lf
*.bat text eol=crlf

# Treat all files as UTF-8
* text=auto

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.wav binary
*.ogg binary
*.mp3 binary
*.ttf binary
*.otf binary
*.scn binary
*.import binary
